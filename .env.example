# CAPITAL INDEX 2026 environment template

GCP_PROJECT_ID=capital-index-2026
GCP_REGION=europe-west1
ARTIFACT_REGISTRY_REPOSITORY=capital-workers
ARTIFACT_REGISTRY_URI=europe-west1-docker.pkg.dev/capital-index-2026/capital-workers

PUBSUB_DRIVE_TEST_TOPIC=capital-events-drive-test
PUBSUB_DRIVE_TEST_SUBSCRIPTION=capital-events-drive-test-sub
PUBSUB_DRIVE_EVENTS_TOPIC=capital.events.drive
PUBSUB_METADATA_JOBS_TOPIC=capital.jobs.metadata
PUBSUB_POLICY_JOBS_TOPIC=capital.jobs.policy
PUBSUB_EXTRACTION_JOBS_TOPIC=capital.jobs.extraction
PUBSUB_AUDIT_TOPIC=capital.audit
PUBSUB_DLQ_TOPIC=capital.dlq

FIRESTORE_DATABASE=(default)
BIGQUERY_DATASET=capital_index

VAULT_ROOT_FOLDER_ID=1No6LMuCpH2T2jmGL7hnFlMto-0gnnHpq

# Do not put real secrets here.

# Admin web public Firebase config.
# NEXT_PUBLIC_* values are visible in the browser and must never contain secrets.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=capital-index-2026
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=capital-index-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=capital-index-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin web server-only config. Do not expose these with NEXT_PUBLIC_.
ADMIN_WEB_FIRESTORE_DATABASE=(default)
ADMIN_WEB_REQUIRE_AUTH=true

# Entity extractor AI provider. Do not put real keys here.
AI_PROVIDER_ENABLED=false
AI_PROVIDER=openai
OPENAI_MODEL_ID=
OPENAI_API_KEY_SECRET_NAME=capital-openai-api-key
GEMINI_MODEL_ID=gemini-2.0-flash
GEMINI_API_KEY_SECRET_NAME=capital-gemini-api-key
