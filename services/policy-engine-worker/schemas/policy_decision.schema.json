{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capital.policy_decision.v1",
  "title": "CAPITAL INDEX policy decision",
  "type": "object",
  "required": [
    "schema_version",
    "decision_id",
    "source",
    "trace_id",
    "idempotency_key",
    "raw_metadata_ref",
    "decided_at",
    "policy_snapshot_id",
    "policy_id",
    "gcp_project_id",
    "project_id",
    "source_registry_id",
    "file_id",
    "sensitivity_class",
    "allowed_actions",
    "denied_actions",
    "approval_required_for",
    "review_required",
    "next_action"
  ],
  "properties": {
    "schema_version": { "const": "capital.policy_decision.v1" },
    "decision_id": { "type": "string", "pattern": "^policy_[a-f0-9]{24}$" },
    "source": { "const": "policy_engine_worker" },
    "source_load_id": { "type": ["string", "null"] },
    "source_event_id": { "type": ["string", "null"] },
    "trace_id": { "type": ["string", "null"] },
    "idempotency_key": { "type": ["string", "null"] },
    "raw_metadata_ref": { "type": "string" },
    "decided_at": { "type": "string" },
    "policy_snapshot_id": { "type": "string" },
    "policy_id": { "type": "string" },
    "policy_name": { "type": "string" },
    "gcp_project_id": { "type": ["string", "null"] },
    "project_id": { "type": ["string", "null"] },
    "source_registry_id": { "type": ["string", "null"] },
    "file_id": { "type": ["string", "null"] },
    "name": { "type": ["string", "null"] },
    "mime_type": { "type": ["string", "null"] },
    "web_view_link": { "type": ["string", "null"] },
    "sensitivity_class": { "type": "string" },
    "allowed_actions": { "type": "array", "items": { "type": "string" } },
    "denied_actions": { "type": "array", "items": { "type": "string" } },
    "approval_required_for": { "type": "array", "items": { "type": "string" } },
    "review_required": { "type": "boolean" },
    "review_reason": { "type": ["string", "null"] },
    "next_action": { "type": "string" }
  }
}
