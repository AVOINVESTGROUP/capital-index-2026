{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capital.source_evidence.v1",
  "title": "CAPITAL INDEX Source Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_id",
    "file_id",
    "source_artifact_id",
    "title",
    "snippet",
    "ai_context_allowed",
    "source_status",
    "index_eligible",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "capital.source_evidence.v1"},
    "evidence_id": {"type": "string", "minLength": 1},
    "file_id": {"type": "string", "minLength": 1},
    "source_artifact_id": {"type": "string", "minLength": 1},
    "drive_url": {"type": ["string", "null"]},
    "title": {"type": "string", "minLength": 1},
    "project_id": {"type": ["string", "null"]},
    "char_count": {"type": "integer", "minimum": 0},
    "snippet": {"type": "string"},
    "ai_context_allowed": {"const": true},
    "source_status": {"const": "active"},
    "index_eligible": {"const": true},
    "created_at": {"type": "string"}
  },
  "additionalProperties": true
}
